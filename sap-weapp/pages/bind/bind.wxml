<!-- 标题 + 说明 -->
<view class="screen-header">
  <text class="title">绑定教务账号</text>
</view>
<view class="intro t-sec t-sm">绑定后由后端安全代抓课表/成绩，密码 AES 加密存储。</view>

<!-- 表单态 -->
<view wx:if="{{stage === 'form'}}" class="card">
  <view class="field">
    <text class="label">学号</text>
    <input class="input" type="number" placeholder="请输入教务学号" value="{{account}}" bindinput="onAccount" />
  </view>
  <view class="hairline"></view>
  <view class="field">
    <text class="label">教务密码</text>
    <input class="input" password placeholder="请输入教务系统密码" value="{{password}}" bindinput="onPassword" />
  </view>
  <button class="btn-accent submit" loading="{{loading}}" disabled="{{loading}}" bindtap="onBind">绑定</button>
</view>

<!-- 验证码态 -->
<view wx:if="{{stage === 'captcha'}}" class="card">
  <text class="step-tip t-sec">请输入下图中的验证码</text>
  <image wx:if="{{captchaSrc}}" class="captcha-img" src="{{captchaSrc}}" mode="aspectFit" />
  <view class="field">
    <text class="label">验证码</text>
    <input class="input" placeholder="请输入图中验证码" value="{{captchaCode}}" bindinput="onCaptcha" />
  </view>
  <button class="btn-accent submit" loading="{{loading}}" disabled="{{loading}}" bindtap="onSubmitCaptcha">提交</button>
  <button class="btn-outline submit2" disabled="{{loading}}" bindtap="backToForm">返回</button>
</view>

<!-- 短信验证态 -->
<view wx:if="{{stage === 'mfa'}}" class="card">
  <text class="step-tip t-sec">已向手机 {{phone}} 发送验证码</text>
  <view class="field">
    <text class="label">短信验证码</text>
    <input class="input" type="number" maxlength="6" placeholder="请输入 6 位短信验证码" value="{{mfaCode}}" bindinput="onMfa" />
  </view>
  <button class="btn-accent submit" loading="{{loading}}" disabled="{{loading}}" bindtap="onSubmitMfa">提交</button>
  <button class="btn-outline submit2" disabled="{{loading}}" bindtap="onResendMfa">重新发送</button>
  <button class="btn-outline submit2" disabled="{{loading}}" bindtap="backToForm">返回</button>
</view>
