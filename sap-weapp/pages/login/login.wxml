<view class="login-page">
  <!-- 品牌区 -->
  <view class="brand">
    <image class="brand-logo" mode="aspectFit"
           src="data:image/svg+xml;base64," />
    <text class="brand-title">软协课表</text>
    <text class="brand-sub">登录协会会员账号，查看课表 · 成绩 · 考试</text>
  </view>

  <!-- 登录表单 -->
  <view class="card login-card">
    <view class="field">
      <view class="field-icon icon-id"></view>
      <input class="field-input" type="text" placeholder="请输入学号" placeholder-class="ph"
             value="{{studentId}}" bindinput="onStudentId" confirm-type="next" />
    </view>
    <view class="field-divider"></view>
    <view class="field">
      <view class="field-icon icon-lock"></view>
      <input class="field-input" password placeholder="请输入密码" placeholder-class="ph"
             value="{{password}}" bindinput="onPassword" confirm-type="done" bindconfirm="onLogin" />
    </view>
  </view>

  <button class="login-btn" bindtap="onLogin" disabled="{{loading || !studentId || !password}}">
    {{loading ? '登录中…' : '登 录'}}
  </button>

  <view class="privacy">登录即表示同意隐私政策</view>
</view>
