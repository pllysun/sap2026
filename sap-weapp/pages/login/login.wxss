/* 登录页：现代化简约风（柔和渐变 + SVG 图标 + 浮起按钮） */
page {
  background: linear-gradient(180deg, #E7F2FE 0%, #F4F8FC 34%, var(--page-bg) 60%);
}

.login-page {
  min-height: 100vh;
  padding: 0 48rpx;
  display: flex;
  flex-direction: column;
}

/* 品牌区 */
.brand {
  text-align: center;
  padding: 168rpx 20rpx 76rpx;
}
.brand-logo {
  width: 150rpx;
  height: 150rpx;
  border-radius: 40rpx;
  box-shadow: 0 18rpx 44rpx rgba(46, 155, 239, 0.32);
}
.brand-title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  margin-top: 34rpx;
  color: var(--text-primary);
}
.brand-sub {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
}

/* 表单卡片 */
.login-card {
  margin: 0 0 44rpx;
  padding: 6rpx 30rpx;
  box-shadow: 0 10rpx 36rpx rgba(31, 35, 41, 0.06);
}
.field {
  display: flex;
  align-items: center;
  height: 116rpx;
}
.field-icon {
  width: 40rpx;
  height: 40rpx;
  flex: 0 0 40rpx;
  margin-right: 24rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}
.icon-id {
  background-image: url("data:image/svg+xml;base64,");
}
.icon-lock {
  background-image: url("data:image/svg+xml;base64,");
}
.field-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
}
.ph { color: var(--text-tertiary); }
.field-divider {
  height: 1rpx;
  background: var(--hairline);
  margin-left: 64rpx;
}

/* 登录按钮（浮起 + 宽字距） */
.login-btn {
  margin: 0;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 22rpx;
  background: var(--accent);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 10rpx;
  text-indent: 10rpx;
  box-shadow: 0 14rpx 30rpx rgba(46, 155, 239, 0.34);
  border: none;
}
.login-btn::after { border: none; }
.login-btn[disabled] {
  opacity: 0.45;
  box-shadow: none;
  color: #fff;
}

/* 隐私提示 */
.privacy {
  text-align: center;
  color: var(--text-tertiary);
  font-size: 24rpx;
  margin-top: auto;
  padding: 64rpx 0 60rpx;
}
