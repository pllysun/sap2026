page { background: var(--surface); }

/* 顶栏 */
.topbar {
  display: flex; align-items: center; height: 96rpx; padding: 0 24rpx;
  background: var(--surface); border-bottom: 1rpx solid var(--hairline);
}
.tb-left { flex: 1; display: flex; align-items: center; overflow: hidden; }
.tb-account { font-size: 30rpx; font-weight: 600; max-width: 240rpx; }
.tb-caret { color: var(--text-tertiary); font-size: 24rpx; margin-left: 8rpx; }
/* 顶栏图标（App 自定义图标集） */
.tb-ic { width: 34rpx; height: 34rpx; margin-left: 8rpx; background-repeat: no-repeat; background-position: center; background-size: contain; }
.ic-swap { background-image: url("data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0ibm9uZSIgc3Ryb2tlPSIjOTA5OEExIiBzdHJva2Utd2lkdGg9IjIiIHN0cm9rZS1saW5lY2FwPSJyb3VuZCIgc3Ryb2tlLWxpbmVqb2luPSJyb3VuZCI+PHBhdGggZD0iTTcgNyBIMTcgTDE0IDQiLz48cGF0aCBkPSJNMTcgMTcgSDcgTDEwIDIwIi8+PC9zdmc+"); }
.ic-dd { width: 30rpx; height: 30rpx; background-image: url("data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0ibm9uZSIgc3Ryb2tlPSIjOTA5OEExIiBzdHJva2Utd2lkdGg9IjIiIHN0cm9rZS1saW5lY2FwPSJyb3VuZCIgc3Ryb2tlLWxpbmVqb2luPSJyb3VuZCI+PHBhdGggZD0iTTcgMTAgTDEyIDE1IEwxNyAxMCIvPjwvc3ZnPg=="); }
.ic-gear { width: 40rpx; height: 40rpx; background-image: url("data:image/svg+xml;base64,"); }
.tb-center { flex: 0 0 auto; display: flex; align-items: center; }
.tb-week { font-size: 32rpx; font-weight: 700; }
.tb-right { flex: 1; display: flex; align-items: center; justify-content: flex-end; }
.tb-term { font-size: 24rpx; color: var(--text-secondary); margin-right: 20rpx; }
.tb-gear { font-size: 36rpx; color: var(--text-secondary); }

/* 星期表头 */
.weekrow { display: flex; height: 104rpx; background: var(--surface); border-bottom: 1rpx solid var(--hairline); }
.time-col { width: 88rpx; flex: 0 0 88rpx; position: relative; }
.weekrow .time-col.head { width: 88rpx; }
.day-head {
  flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
  border-left: 1rpx solid var(--hairline);
}
.day-head.today { background: rgba(46,155,239,0.10); }
.dh-name { font-size: 25rpx; font-weight: 600; }
.dh-date { font-size: 20rpx; color: var(--text-tertiary); margin-top: 4rpx; }
.day-head.today .dh-name, .day-head.today .dh-date { color: var(--accent); }

/* 网格 */
.weeks-swiper { width: 100%; }
.grid-scroll { width: 100%; }
.grid-body { display: flex; position: relative; }

.time-col .time-cell {
  position: absolute; left: 0; width: 88rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.tc-node { font-size: 24rpx; font-weight: 600; color: var(--text-secondary); }
.tc-time { font-size: 17rpx; color: var(--text-tertiary); line-height: 1.3; }

.day-col { flex: 1; position: relative; border-left: 1rpx solid var(--hairline); }

.course-card {
  position: absolute; box-sizing: border-box;
  border-radius: 12rpx; padding: 8rpx 8rpx; overflow: hidden;
  display: flex; flex-direction: column;
}
.course-card.faded { opacity: 0.42; }
.cc-name { font-weight: 600; line-height: 1.2; }
.cc-room { line-height: 1.25; margin-top: 2rpx; opacity: 0.92; }
.cc-corner {
  position: absolute; right: 0; top: 0;
  border-width: 12rpx; border-style: solid;
  border-color: rgba(0,0,0,0.18) rgba(0,0,0,0.18) transparent transparent;
}

/* 备注 */
.remarks { margin: 20rpx 24rpx 0; }
.remarks-title { font-size: 24rpx; color: var(--text-tertiary); margin-bottom: 12rpx; }
.remark-item {
  display: flex; align-items: center;
  background: var(--surface); border: 1rpx solid var(--hairline);
  border-radius: 16rpx; padding: 22rpx 24rpx; margin-bottom: 12rpx;
}
.ri-left { flex: 1; min-width: 0; display: flex; flex-direction: column; }
.ri-name { font-size: 28rpx; font-weight: 500; }
.ri-sub { font-size: 22rpx; color: var(--text-secondary); margin-top: 4rpx; }
.ri-arrow { flex: 0 0 auto; margin-left: 16rpx; font-size: 24rpx; color: var(--accent); }

/* FAB */
.fab {
  position: fixed; right: 40rpx; bottom: 60rpx; width: 96rpx; height: 96rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 10rpx 28rpx rgba(46,155,239,0.36); z-index: 20;
}
.fab-add {
  width: 48rpx; height: 48rpx;
  background-repeat: no-repeat; background-position: center; background-size: contain;
  background-image: url("data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0ibm9uZSIgc3Ryb2tlPSIjRkZGRkZGIiBzdHJva2Utd2lkdGg9IjIuNCIgc3Ryb2tlLWxpbmVjYXA9InJvdW5kIiBzdHJva2UtbGluZWpvaW49InJvdW5kIj48cGF0aCBkPSJNMTIgNSBWMTkiLz48cGF0aCBkPSJNNSAxMiBIMTkiLz48L3N2Zz4="); }

.float-tip {
  position: fixed; top: 220rpx; left: 50%; transform: translateX(-50%);
  background: rgba(0,0,0,0.7); color: #fff; font-size: 24rpx;
  padding: 12rpx 28rpx; border-radius: 30rpx; z-index: 30;
}
.bind-btn { margin: 40rpx auto 0; width: 60%; }

/* 弹层通用 */
.mask { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 50; display: flex; align-items: flex-end; }
.sheet { width: 100%; background: var(--surface); border-radius: 28rpx 28rpx 0 0; padding: 28rpx; max-height: 70vh; }
.sheet-head { display: flex; justify-content: space-between; align-items: center; font-size: 30rpx; font-weight: 600; margin-bottom: 24rpx; }
.sheet-act { font-size: 26rpx; color: var(--accent); font-weight: 400; }
.week-grid-wrap { max-height: 50vh; }
.week-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.week-chip {
  width: 96rpx; height: 76rpx; border-radius: 12rpx; background: var(--surface-muted);
  display: flex; align-items: center; justify-content: center; font-size: 28rpx;
}
.week-chip.cur { border: 2rpx solid var(--accent); color: var(--accent); }
.week-chip.on { background: var(--accent); color: #fff; }

.opt-row { display: flex; justify-content: space-between; align-items: center; padding: 26rpx 8rpx; border-bottom: 1rpx solid var(--hairline); font-size: 29rpx; }
.opt-row.on { color: var(--accent); }
.opt-tick { color: var(--accent); }

/* 详情 */
.detail-card { width: 100%; background: var(--surface); border-radius: 28rpx 28rpx 0 0; padding: 36rpx 36rpx 60rpx; }
.dc-name { font-size: 36rpx; font-weight: 700; margin-bottom: 24rpx; }
.dc-row { display: flex; padding: 12rpx 0; font-size: 28rpx; }
.dc-k { width: 120rpx; color: var(--text-tertiary); }
.dc-actions { display: flex; gap: 24rpx; margin-top: 28rpx; }
.dc-btn { flex: 1; }
