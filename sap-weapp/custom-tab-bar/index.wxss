.tabbar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  display: flex;
  background: #FFFFFF;
  border-top: 1rpx solid #EDEFF2;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 16rpx rgba(31, 35, 41, 0.04);
}
.tab {
  flex: 1;
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.tab-ic { width: 46rpx; height: 46rpx; }
.tab-txt { font-size: 20rpx; margin-top: 6rpx; line-height: 1; }
