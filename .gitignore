# ==============================================
# SAP 项目根目录 .gitignore
# ==============================================

# ===== IDE / 编辑器 =====
.idea/
.vscode/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ===== 操作系统 =====
.DS_Store
Thumbs.db
desktop.ini

# ===== Node.js =====
**/node_modules/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ===== Java / Maven =====
**/target/
*.class
*.jar
!.mvn/wrapper/*.jar
*.war

# ===== 前端构建产物 =====
sap-admin/dist/
sap-user/dist/
**/dist-ssr/

# ===== 敏感配置文件 =====
# 真实环境配置包含数据库密码等信息，不提交到仓库
# 请复制 .example 文件并重命名后使用
sap-backend/src/main/resources/application-dev.yml
sap-backend/src/main/resources/application-prod.yml
# Docker 生产环境变量（含 JW_AES_KEY/MySQL 密码），仅保留 .env.example
docker/.env
.env
# 安卓签名密钥
**/keystore.properties
**/*.jks
**/*.keystore

# ===== 打包产物（APK 输出目录）=====
/release/

# ===== 日志 =====
*.log
logs/

# ===== 测试 / 工具脚本 =====
**/test-cos-integration.ps1
**/query_old_db.js

# ===== Docker 数据 =====
**/data/
**/uploads/

# ===== Python（OCR sidecar）=====
# 虚拟环境/字节码体积大且平台相关，绝不入库；靠 requirements.txt 重建
**/.venv/
**/venv/
**/__pycache__/
*.py[cod]
*.egg-info/

# ===== Gemini AI =====
.gemini/

# ===== App 发版产物（APK 体积大，不入库；按版本归档在本地/分发渠道）=====
/release/
