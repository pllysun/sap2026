# ===== sap2026 正式环境变量：复制为 docker/.env 后填写（.env 已被 .gitignore 排除，勿入库）=====

# 域名：设置后容器会用 certbot 自动签发 Let's Encrypt HTTPS 证书
DOMAIN=csuftsap.top
SSL_EMAIL=admin@csuftsap.top

# 教务密码 AES 密钥（32 字节）——【生产必填】，否则容器拒绝启动。
# 丢失或更换 = 所有已绑定教务凭据无法解密，需用户重新绑定，务必长期妥善保存。
# 生成：openssl rand -base64 24 | cut -c1-32
JW_AES_KEY=

# 外部 MySQL（推荐）。留空则用容器内置 H2 文件库(仅适合体验/小规模，存 /app/data 卷)。
# 用 compose 自带 mysql 服务时，host 改为 mysql:3306。
MYSQL_URL=jdbc:mysql://host.docker.internal:3306/sap?serverTimezone=Asia/Shanghai&useSSL=false&useUnicode=true&characterEncoding=UTF-8
MYSQL_USER=sap
MYSQL_PASSWORD=

# JVM 参数
JAVA_OPTS=-Xms256m -Xmx512m

# 腾讯云 COS 密钥不在这里配！启动后到管理端「系统设置 → 对象存储」填入（存数据库 Setting 表）。
