# ============================
# 生产环境配置 (Production)
# ============================
# 激活方式：
#   1. 命令行：java -jar xxx.jar --spring.profiles.active=prod
#   2. 环境变量：SPRING_PROFILES_ACTIVE=prod
#
# 使用方法：
#   1. 复制本文件并重命名为 application-prod.yml
#   2. 填入你的生产数据库连接信息
#   3. application-prod.yml 已被 .gitignore 排除，不会提交到仓库

spring:
  datasource:
    url: jdbc:mysql://your-production-host:3306/sap?serverTimezone=Asia/Shanghai
    username: your_username
    password: your_password
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    show-sql: false

mybatis-plus:
  configuration:
    log-impl: org.apache.ibatis.logging.nologging.NoLoggingImpl
