# ============================
# 开发环境配置 (Development)
# ============================
# 激活方式：
#   1. 默认激活（application.yml 中已设置）
#   2. 命令行：java -jar xxx.jar --spring.profiles.active=dev
#   3. 环境变量：SPRING_PROFILES_ACTIVE=dev
#
# 使用方法：
#   1. 复制本文件并重命名为 application-dev.yml
#   2. 填入你的数据库连接信息
#   3. application-dev.yml 已被 .gitignore 排除，不会提交到仓库

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/sap_db?serverTimezone=Asia/Shanghai
    username: your_username
    password: your_password
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    show-sql: true

mybatis-plus:
  configuration:
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl
